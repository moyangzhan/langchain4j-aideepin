# 复制本文件为 application-dev.yml，并填入真实的数据库、Redis 等连接信息
# 注意：application-dev.yml 已在 .gitignore 中，不会被提交到代码仓库
# 敏感信息通过环境变量注入，格式为 ${ADI_XXX:默认值}

spring:
  datasource:
    driver-class-name: org.postgresql.Driver
    url: jdbc:postgresql://${ADI_DB_HOST:localhost}:${ADI_DB_PORT:5432}/${ADI_DB_NAME:postgres}?useUnicode=true&characterEncoding=utf8&serverTimezone=GMT%2B8&tinyInt1isBit=false&allowMultiQueries=true
    username: ${ADI_DB_USERNAME:your-username}
    password: ${ADI_DB_PASSWORD:your-password}
    hikari:
      connection-timeout: 10000
      validation-timeout: 3000
      idle-timeout: 60000
      login-timeout: 5
      max-lifetime: 300000
      maximum-pool-size: 10
      minimum-idle: 5
      read-only: false
  data:
    redis:
      host: ${ADI_REDIS_HOST:localhost}
      port: ${ADI_REDIS_PORT:6379}
      password: ${ADI_REDIS_PASSWORD:}
      database: 0
      lettuce:
        pool:
          max-active: 20
          max-wait: -1
          max-idle: 5
          min-idle: 1

logging:
  file:
    path: ./data/aideepin/logs
  level:
    com.baomidou.mybatisplus: DEBUG

adi:
  frontend-url: http://localhost:1002
  backend-url: http://localhost:1002/api
  proxy:
    enable: false
    host: 127.0.0.1
    http-port: 1087
  # embedding model可选值如下（见adi_ai_model中的embedding类型的数据）：
  # local:all-minilm-l6-v2 (英文效果较好，中文效果较差)
  # local:bge-small-zh-v1.5 (默认、中文效果较好、相比 all-minilm-l6-v2 占用内存较大)
  # openai:text-embedding-3-small、openai:text-embedding-3-large (多语言)
  # dashscope:text-embedding-v1、dashscope:text-embedding-v3  (多语言，中文效果较好)
  # 注意：由于不同向量模型不同维度参数生成的向量特征空间不一致，无法兼容存储于一张表并进行混合搜索，建议项目初期确定好向量模型及其维度，后期如有修改，需重新生成向量数据
  embedding-model: local:bge-small-zh-v1.5
  # vector-database: pgvector、neo4j
  vector-database: pgvector
  # graph-database: apache-age、neo4j
  graph-database: apache-age
  datasource:
    neo4j:
      host: ${ADI_NEO4J_HOST:localhost}
      port: ${ADI_NEO4J_PORT:7687}
      username: ${ADI_NEO4J_USERNAME:neo4j}
      password: ${ADI_NEO4J_PASSWORD:your-db-password}
      database: ${ADI_NEO4J_DATABASE:neo4j}

local:
  base-data-path: ${ADI_LOCAL_BASE_DATA_PATH:./data/aideepin}
  files: ${local.base-data-path}/files/
  images: ${local.base-data-path}/images/
  watermark-images: ${local.base-data-path}/mark-images/
  thumbnails: ${local.base-data-path}/thumbnails/
  watermark-thumbnails: ${local.base-data-path}/watermark-thumbnails/
  tmp-images: ${local.base-data-path}/tmp-images/
  chat-memory: ${local.base-data-path}/chat-memory/
